APP_NAME=BolBazaar Google Stack API
APP_ENV=development
API_V1_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
STORAGE_MODE=local
ALLOW_LOCAL_FALLBACK=true
DATA_FILE=./data/demo_db.json
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GCP_PROJECT_ID=your_gcp_project_id
FIREBASE_PROJECT_ID=your_firebase_project_id
MAPS_API_KEY=your_google_maps_api_key
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_GRAPH_VERSION=v24.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=hi-IN
DEMAND_PUSH_THRESHOLD=3
DEMAND_PUSH_WINDOW_MINUTES=30
DEMAND_PUSH_COOLDOWN_MINUTES=30
DELIVERY_BASE_FEE=35
DELIVERY_MIN_FEE=45
DELIVERY_PER_KM_FEE=12
DELIVERY_FREE_RADIUS_KM=0
DELIVERY_WEIGHT_INCLUDED_KG=10
DELIVERY_PER_EXTRA_KG_FEE=0.75
DELIVERY_MAX_FEE=500
DELIVERY_SURGE_MULTIPLIER=1.0
MANDI_PRICE_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
MANDI_PRICE_API_KEY=your_data_gov_api_key
MANDI_PRICE_CACHE_TTL_MINUTES=360
MANDI_PRICE_DEFAULT_STATE=Maharashtra
MANDI_PRICE_DEFAULT_MARKET=Pune
MANDI_PRICE_DEFAULT_PRICE_UNIT=quintal
DYNAMIC_PRICING_MARGIN_PERCENT=8
DYNAMIC_PRICING_PREMIUM_QUALITY_UPLIFT_PERCENT=7
DYNAMIC_PRICING_ECONOMY_DISCOUNT_PERCENT=5
