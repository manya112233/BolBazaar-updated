APP_NAME=BolBazaar Google Stack API
APP_ENV=development
API_V1_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
STORAGE_MODE=firestore
ALLOW_LOCAL_FALLBACK=true
DATA_FILE=./data/demo_db.json
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=
MAPS_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_VERSION=v24.0
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=hi-IN
DEMAND_PUSH_THRESHOLD=3
DEMAND_PUSH_WINDOW_MINUTES=30
DEMAND_PUSH_COOLDOWN_MINUTES=30
POOL_WINDOW_HOURS=12
POOL_MIN_BUYERS=2
POOL_GEO_BUCKET_DECIMALS=2
DELIVERY_BASE_FEE=20.0
DELIVERY_PER_KM_FEE=8.0
DELIVERY_FREE_RADIUS_KM=1.0
